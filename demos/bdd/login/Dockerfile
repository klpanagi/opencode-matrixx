# syntax=docker/dockerfile:1.7
# ---------------------------------------------------------------------------
# Login BDD Generated Test Runner
#
# Runs Cucumber tests against the generated `demos/bdd/login/` feature.
# Generated by the bdd-tests pipeline — one per feature, build context = repo root.
#
# Build:
#   docker build -f demos/bdd/login/Dockerfile -t matrixx-bdd-login .
#
# Run (default cucumber args):
#   docker run --rm matrixx-bdd-login
#
# Pass extra cucumber args (e.g. tag filter):
#   docker run --rm -e BDD_ARGS="--tags @happy-path" matrixx-bdd-login
#
# Override base URL (defaults to http://localhost:4000 inside the container):
#   docker run --rm -e BDD_BASE_URL=http://host.docker.internal:4000 matrixx-bdd-login
# ---------------------------------------------------------------------------

ARG BUN_VERSION=1.3.6
FROM oven/bun:${BUN_VERSION} AS base

# System dependencies required by Playwright chromium at runtime.
# Using the official oven/bun Debian image — no extra packages needed for Bun itself.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libexpat1 \
    libfontconfig1 \
    libgbm1 \
    libgcc-s1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libstdc++6 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxcursor1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxi6 \
    libxrandr2 \
    libxrender1 \
    libxss1 \
    libxtst6 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- 1. Install JS dependencies (use --frozen-lockfile for reproducibility) ---
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile

# --- 2. Install Playwright chromium browser + OS deps ---
# The chromium binary is downloaded at build time; the OS deps are already installed above.
RUN bunx playwright install chromium

# --- 3. Copy only what tests need: this feature dir + the bdd runtime ---
COPY demos/bdd ./demos/bdd
COPY src/features/bdd ./src/features/bdd

# --- 4. Make the runner executable ---
RUN chmod +x ./demos/bdd/login/run-tests.sh

# --- 5. Defaults baked into the image for this feature ---
ENV BDD_BASE_URL=http://localhost:4000
ENV BDD_PREVIEW_DIR=/app/demos/bdd/login/components
ENV BDD_TEST_DIR=/app/demos/bdd/login/tests
ENV PREVIEW_PORT=4000
ENV CI=true

# --- 6. Entrypoint ---
WORKDIR /app/demos/bdd/login
CMD ["bash", "run-tests.sh"]

# syntax=docker/dockerfile:1.7
# ---------------------------------------------------------------------------
# Batch BDD Generated Test Runner
#
# Runs the per-feature run-tests.sh for every generated feature under
# demos/bdd/. Generated by the bdd-tests pipeline when the input is a
# directory of multiple .feature files.
#
# Build:
#   docker build -f demos/bdd/Dockerfile -t matrixx-bdd .
#
# Run all features (default):
#   docker run --rm matrixx-bdd
#
# Run a single feature:
#   docker run --rm -e BDD_FEATURE=login matrixx-bdd
#
# Pass extra cucumber args (e.g. tag filter):
#   docker run --rm -e BDD_ARGS="--tags @happy-path" matrixx-bdd
#
# Override base URL (defaults to http://localhost:4000 inside the container):
#   docker run --rm -e BDD_BASE_URL=http://host.docker.internal:4000 matrixx-bdd
# ---------------------------------------------------------------------------

ARG BUN_VERSION=1.3.6
FROM oven/bun:${BUN_VERSION} AS base

# System dependencies required by Playwright chromium at runtime.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcairo2 \
    libcups2 \
    libdbus-1-3 \
    libexpat1 \
    libfontconfig1 \
    libgbm1 \
    libgcc-s1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libstdc++6 \
    libx11-6 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxcursor1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxi6 \
    libxrandr2 \
    libxrender1 \
    libxss1 \
    libxtst6 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- 1. Install JS dependencies (use --frozen-lockfile for reproducibility) ---
COPY package.json bun.lock* ./
RUN bun install --frozen-lockfile

# --- 2. Install Playwright chromium browser (OS deps already installed) ---
RUN bunx playwright install chromium

# --- 3. Copy the BDD tree (features + the bdd runtime) ---
COPY demos/bdd ./demos/bdd
COPY src/features/bdd ./src/features/bdd

# --- 4. Make the parent + every per-feature runner executable ---
RUN chmod +x ./demos/bdd/run-tests.sh
RUN find ./demos/bdd -name "run-tests.sh" -exec chmod +x {} +

# --- 5. Defaults baked into the image ---
ENV BDD_BASE_URL=http://localhost:4000
ENV PREVIEW_PORT=4000
ENV CI=true

# --- 6. Entrypoint: the parent runner iterates every feature ---
WORKDIR /app/demos/bdd
CMD ["bash", "run-tests.sh"]
